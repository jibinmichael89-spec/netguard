# NetGuard Windows Home — installed to C:\ProgramData\NetGuard\netguard.env
NETGUARD_PROFILE=home
NETGUARD_DB_PATH=C:\ProgramData\NetGuard\netguard.db
NETGUARD_REQUIRE_DEVICE_APPROVAL=1

# Notifications — configure via dashboard Settings
# NETGUARD_TELEGRAM_BOT_TOKEN=
# NETGUARD_ALERT_EMAIL_TO=

# Optional API key
# NETGUARD_API_KEY=
