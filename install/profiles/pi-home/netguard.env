# NetGuard Pi Home — single-user profile
# Installed to /etc/netguard/netguard.env by install.sh

NETGUARD_PROFILE=home
NETGUARD_DB_PATH=/var/lib/netguard/netguard.db
NETGUARD_LOG_DIR=/var/log/netguard
DNSMASQ_LOG_PATH=/var/log/netguard/dnsmasq.log
NETGUARD_REQUIRE_DEVICE_APPROVAL=1

# Optional gateway override
# NETGUARD_GATEWAY_IP=192.168.1.1

# Notifications — or configure via dashboard Settings
# NETGUARD_TELEGRAM_BOT_TOKEN=
# NETGUARD_TELEGRAM_CHAT_ID=
# NETGUARD_SMTP_HOST=
# NETGUARD_SMTP_PORT=587
# NETGUARD_SMTP_USER=
# NETGUARD_SMTP_PASSWORD=
# NETGUARD_SMTP_FROM=
# NETGUARD_ALERT_EMAIL_TO=

# Optional API key
# NETGUARD_API_KEY=

# Router enforcement (optional)
# NETGUARD_ROUTER_TYPE=openwrt
# NETGUARD_ROUTER_URL=http://192.168.1.1
# NETGUARD_ROUTER_USER=root
# NETGUARD_ROUTER_PASSWORD=

# MSP — disabled for home profile
# NETGUARD_MSP_COLLECTOR_URL=
# NETGUARD_SITE_TOKEN=
# NETGUARD_SITE_ID=default
