# NetGuard Pi MSP — managed site profile
# Edit collector URL and tokens before running install.sh

NETGUARD_PROFILE=msp
NETGUARD_DB_PATH=/var/lib/netguard/netguard.db
NETGUARD_LOG_DIR=/var/log/netguard
DNSMASQ_LOG_PATH=/var/log/netguard/dnsmasq.log
NETGUARD_REQUIRE_DEVICE_APPROVAL=1

# === REQUIRED for MSP — set before install ===
NETGUARD_MSP_COLLECTOR_URL=https://msp.example.com:8000
NETGUARD_SITE_TOKEN=change-me-site-token
NETGUARD_SITE_ID=customer-site-01

# Optional gateway override
# NETGUARD_GATEWAY_IP=192.168.1.1

# Notifications
# NETGUARD_TELEGRAM_BOT_TOKEN=
# NETGUARD_ALERT_EMAIL_TO=

# Optional API key
# NETGUARD_API_KEY=

# Router enforcement (optional)
# NETGUARD_ROUTER_TYPE=openwrt
# NETGUARD_ROUTER_URL=http://192.168.1.1
