[Unit]
Description=NetGuard Policy Engine
After=netguard-arp-scanner.service

[Service]
Type=simple
User=netguard
WorkingDirectory=/opt/netguard
Environment=PYTHONPATH=/opt/netguard/daemon
EnvironmentFile=-/etc/netguard/netguard.env
ExecStart=/opt/netguard/venv/bin/python daemon/detection/policy_engine.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=netguard.target
