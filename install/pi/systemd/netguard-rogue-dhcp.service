[Unit]
Description=NetGuard Rogue DHCP Detector
After=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/netguard
EnvironmentFile=/etc/netguard/netguard.env
ExecStart=/opt/netguard/venv/bin/python daemon/detection/rogue_dhcp_detector.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=netguard.target
