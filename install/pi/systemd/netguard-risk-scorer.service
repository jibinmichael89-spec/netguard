[Unit]
Description=NetGuard Device Risk Scorer
After=network-online.target netguard-arp-scanner.service
Wants=network-online.target

[Service]
Type=simple
User=netguard
Group=netguard
WorkingDirectory=/opt/netguard
EnvironmentFile=/etc/netguard/netguard.env
ExecStart=/opt/netguard/venv/bin/python daemon/detection/risk_scorer.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=netguard.target
